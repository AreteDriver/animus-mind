{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://animus.local/schemas/lesson.schema.json",
  "title": "Animus Lesson Object",
  "allOf": [
    {
      "$ref": "common.schema.json"
    },
    {
      "type": "object",
      "properties": {
        "artifact_type": {
          "const": "lesson"
        },
        "schema_id": {
          "const": "https://animus.local/schemas/lesson.schema.json"
        },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "statement",
            "evidence_refs",
            "scope",
            "confidence",
            "application_conditions"
          ],
          "properties": {
            "statement": {
              "type": "string",
              "minLength": 1
            },
            "evidence_refs": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "minItems": 1
            },
            "scope": {
              "type": "string",
              "minLength": 1
            },
            "confidence": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "application_conditions": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "minItems": 1
            },
            "counterexamples": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  ]
}
