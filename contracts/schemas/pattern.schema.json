{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://animus.local/schemas/pattern.schema.json",
  "title": "Animus Pattern Object",
  "allOf": [
    {
      "$ref": "common.schema.json"
    },
    {
      "type": "object",
      "properties": {
        "artifact_type": {
          "const": "pattern"
        },
        "schema_id": {
          "const": "https://animus.local/schemas/pattern.schema.json"
        },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "description",
            "signal_refs",
            "support_count",
            "independence_score",
            "method"
          ],
          "properties": {
            "description": {
              "type": "string",
              "minLength": 1
            },
            "signal_refs": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "minItems": 2,
              "uniqueItems": true
            },
            "support_count": {
              "type": "integer",
              "minimum": 2
            },
            "independence_score": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "method": {
              "type": "string",
              "minLength": 1
            },
            "counterexamples": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  ]
}
